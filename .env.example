# Copy to .env and adjust as needed. .env is gitignored.

# --- Database (local dev only; production uses RDS + IAM auth, no password) ---
POSTGRES_DB=personal_crm
POSTGRES_USER=personal_crm_dev
POSTGRES_PASSWORD=devpassword

# --- API ---
# Seed the prototype demo dataset on first startup (dev convenience).
SEED_DATA=true
CORS_ORIGINS=http://localhost:5173

# --- Acme Auth (Acme Games OIDC broker) ---
# Leave ACME_AUTH_JWKS_URL empty to DISABLE auth locally (dev bypass).
# To test real auth, register the app in Acme Auth and fill these in.
ACME_AUTH_ISSUER=
ACME_AUTH_JWKS_URL=
ACME_AUTH_AUDIENCE=
ACME_AUTH_CLIENT_ID=

# --- UI ---
VITE_API_URL=http://localhost:8080
